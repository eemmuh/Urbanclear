# Urbanclear Traffic System - Environment Variables
# Copy this file to .env and update with your actual values
# NEVER commit .env to version control!
#
# Cost: This stack uses open-source dependencies and public container images — no
# license fee to build. Optional Geoapify/OpenRouteService keys use their free tiers.
# See docs/guides/FREE_BUILD_AND_SECURITY.md

# ==========================================
# Application Settings
# ==========================================
ENVIRONMENT=development  # development, staging, production
HOST=127.0.0.1  # Use 0.0.0.0 only when needed
PORT=8000

# ==========================================
# Security - REQUIRED IN PRODUCTION
# ==========================================
# Generate a strong secret key: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-secret-key-change-in-production-minimum-32-characters
ALLOW_DEV_AUTH_BYPASS=false  # Set to true ONLY in development

# ==========================================
# CORS Configuration
# ==========================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ==========================================
# Database Credentials
# ==========================================
POSTGRES_DB=traffic_db
POSTGRES_USER=traffic_user
POSTGRES_PASSWORD=your_secure_postgres_password_here

MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=your_secure_mongo_password_here
MONGO_DATABASE=traffic_logs

REDIS_PASSWORD=your_secure_redis_password_here

# ==========================================
# External API Keys (Optional)
# ==========================================
GEOAPIFY_API_KEY=your_geoapify_api_key_here
OPENROUTESERVICE_API_KEY=your_openrouteservice_api_key_here

# ==========================================
# Monitoring (Optional)
# ==========================================
GRAFANA_ADMIN_PASSWORD=your_grafana_admin_password_here
