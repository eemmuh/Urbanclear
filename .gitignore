# Urbanclear Traffic System - .gitignore

# ==============================================
# Python
# ==============================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg
MANIFEST

# Virtual Environments
venv/
env/
ENV/
.venv/
.uv/
uv.lock
urbanclear-env/

# ==============================================
# Testing & Coverage
# ==============================================
.pytest_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
*.cover
coverage.xml
nosetests.xml
.hypothesis/

# ==============================================
# React Dashboard (Node.js/React)
# ==============================================
dashboard/node_modules/
dashboard/.npm
dashboard/.eslintcache
dashboard/dist/
dashboard/build/
dashboard/.vite/

# Dashboard environment files
dashboard/.env
dashboard/.env.local
dashboard/.env.*.local

# Dashboard logs
dashboard/npm-debug.log*
dashboard/yarn-debug.log*
dashboard/yarn-error.log*

# ==============================================
# Environment Variables & Secrets
# ==============================================
.env
.env.local
.env.*.local
!.env.example

# Configuration files with secrets
config/config.yaml
config/config.yml
config/*.secret.*
config/production.*
config/staging.*
config/secrets.yaml
config/api_keys.yaml

# ==============================================
# Machine Learning Models
# ==============================================
models/trained/
models/simple_trained/
*.pkl
*.joblib
*.h5
*.pt
*.pth
*.model
*.weights

# MLflow (if used)
mlruns/
mlartifacts/

# ==============================================
# Data Files
# ==============================================
data/raw/*.csv
data/raw/*.json
data/raw/*.parquet
data/processed/
data/interim/
data/external/
!data/sample/

# ==============================================
# Database Files
# ==============================================
*.db
*.sqlite
*.sqlite3
*.backup
*.sql.gz
*.dump
*.bson
dump.rdb
appendonly.aof

# ==============================================
# Logs
# ==============================================
logs/
*.log
*.log.*
log/
urbanclear.log
traffic.log
api.log
ml.log
security.log

# ==============================================
# Monitoring Data
# ==============================================
prometheus_data/
grafana_data/

# ==============================================
# Docker
# ==============================================
docker-compose.override.yml
docker-compose.local.yml

# ==============================================
# Security & Secrets
# ==============================================
*.pem
*.key
*.crt
*.csr
*.p12
*.pfx
jwt_secret.txt
*.secret
api_keys.txt
.api_key
ssl/
certs/
certificates/

# ==============================================
# IDEs and Editors
# ==============================================
.vscode/
.idea/
*.swp
*.swo
*~

# ==============================================
# Operating System Files
# ==============================================
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db

# ==============================================
# Temporary & Cache Files
# ==============================================
tmp/
temp/
*.tmp
*.temp
*.cache
.cache/
.ruff_cache/

# Backup files
*.bak
*.backup
*.old
*.orig

# ==============================================
# Project Specific
# ==============================================
# Scripts output
scripts/output/
scripts/logs/

# Health check files
health_*.json
status_*.json

# Performance benchmarks
benchmarks/
performance/

# Project-specific caches
traffic_data_large/
sensor_backups/
incident_archives/
route_cache/
prediction_cache/
